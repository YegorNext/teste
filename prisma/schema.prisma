// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//User schema
model User {
  id        String   @id @default(uuid())
  name      String   @unique
  password  String
  role      Role     @default(USER)
  teamId    String?
  team      Team?    @relation(fields: [teamId], references: [id], onDelete: SetNull)
  servers   Server[] 
  archives  Archive[]
  campaigns String[]
  token     String?
  tokenVersion Int   @default(0)
  tokenExpiry DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// roles
enum Role {
  ADMIN
  USER
}

// Team schema
model Team {
  id      String @id @default(uuid())
  name    String @unique
  members User[]
  alias   String @default("")
}

//Archive schema
model Archive {
  id      String @id @default(uuid())
  name    String
  path    String
  userId  String
  user    User         @relation(fields: [userId], references: [id])
  createdAt DateTime   @default(now())
}



///// Server and Domain schemas

enum DomainType {
  INTERNAL
  EXTERNAL
}

model Server {
  id            String   @id @default(uuid())
  name          String   @unique
  ip            String
  rootPassword  String
  forgePassword String
  userId        String?
  user          User?    @relation(fields: [userId], references: [id])

  domains       Domain[]

  price         Float    @default(0)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  expiredAt     DateTime @default(dbgenerated("(now() + interval '1 month' - interval '1 day')"))
}

model Domain {
  id        String      @id @default(uuid())
  name      String      @unique
  type      DomainType

  serverId  String?
  server    Server?     @relation(fields: [serverId], references: [id], onDelete: SetNull)

  price     Float       @default(0)
  repoId    String
  sshUrl    String
  hasSSL    Boolean     @default(false)
  campaign  String      @default("")

  internal  InternalDomain?
  external  ExternalDomain?
}

model InternalDomain {
  domainId     String   @id
  domain       Domain   @relation(fields: [domainId], references: [id])
}

model ExternalDomain {
  domainId String   @id
  domain   Domain   @relation(fields: [domainId], references: [id])
}

model ForbiddenWord {
  id        String   @id @default(uuid())
  word      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([word])
  @@index([isActive])
}